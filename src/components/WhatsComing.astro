---
interface Item {
  number: string;
  title: string;
  tagline: string;
  icon: 'line' | 'window' | 'eight' | 'seal';
  sentence?: string;
}

interface Props {
  title: string;
  items: Item[];
}

const { title, items } = Astro.props;
---

<section id="whats-coming" class="py-24 md:py-32 bg-secondary">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-semibold text-ivory text-center mb-20 md:mb-24">
      {title}
    </h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {items.map((item) => (
        <article class="group text-center p-8 rounded-xl border border-ivory/20 bg-ivory/5 hover:bg-ivory/10 hover:border-ivory/30 transition-all duration-300">
          <div class="flex justify-center mb-6 text-ivory">
            {item.icon === 'line' && (
              <div class="w-16 h-16 rounded-full border-2 border-ivory/60 flex items-center justify-center group-hover:border-ivory group-hover:scale-105 transition-all">
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden>
                  <path d="M12 3v18M3 12h18M8 8l8 8M16 8l-8 8" />
                </svg>
              </div>
            )}
            {item.icon === 'window' && (
              <div class="w-16 h-16 rounded-full border-2 border-ivory/60 flex items-center justify-center group-hover:border-ivory group-hover:scale-105 transition-all">
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden>
                  <path d="M3 6h18v12H3V6zM3 10h18M10 3v18" />
                </svg>
              </div>
            )}
            {item.icon === 'eight' && (
              <div class="w-16 h-16 rounded-full border-2 border-ivory/60 flex items-center justify-center group-hover:border-ivory group-hover:scale-105 transition-all">
                <span class="font-display text-3xl font-semibold text-ivory">8</span>
              </div>
            )}
            {item.icon === 'seal' && (
              <div class="w-16 h-16 rounded-full border-2 border-ivory/60 flex items-center justify-center group-hover:border-ivory group-hover:scale-105 transition-all">
                <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden>
                  <path d="M12 2L15 8l6 1-4 4 1 6-6-3-6 3 1-6-4-4 6-1L12 2z" />
                </svg>
              </div>
            )}
          </div>
          <p class="font-display text-ivory/60 text-xs font-semibold tracking-widest uppercase mb-2">{item.number}</p>
          <h3 class="font-display text-ivory text-lg font-semibold mb-2">{item.title}</h3>
          <p class="font-sans text-ivory/75 text-sm leading-relaxed mb-3">{item.tagline}</p>
          {item.sentence && <p class="font-sans text-ivory/60 text-sm leading-relaxed">{item.sentence}</p>}
        </article>
      ))}
    </div>
  </div>
</section>
